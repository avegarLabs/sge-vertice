# Dumps SQL — no versionar por defecto (pueden ser grandes / contener PII).
# Para versionar uno pequeño y no sensible: `git add -f db/initdb/<file>.sql`
db/initdb/*.sql
db/initdb/*.sql.gz
db/initdb/*.sql.xz