# =====================================================================
# Variables de entorno para sge-vertice
# Copiar a `.env` y ajustar valores. NO comitear `.env`.
# =====================================================================

# ---- Django ----------------------------------------------------------
# Genera una clave nueva en producción, por ejemplo:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-insecure-key-CHANGE-ME-in-production

# 1 = activado, 0 = desactivado. Siempre 0 en producción.
DJANGO_DEBUG=1

# Lista separada por comas. En producción incluir el dominio real.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Rutas absolutas dentro del contenedor para estáticos y media.
DJANGO_STATIC_ROOT=/app/staticfiles
DJANGO_MEDIA_ROOT=/app/media

# ---- Localización ----------------------------------------------------
LANGUAGE_CODE=es-es
TIME_ZONE=America/Havana

# ---- Base de datos PostgreSQL ---------------------------------------
# `DB_HOST=db` apunta al servicio de docker-compose.
DB_HOST=db
DB_PORT=5432
DB_NAME=rechum
DB_USER=rechum
DB_PASSWORD=change-me-in-production

# Variables que consume la imagen oficial de postgres al inicializarse.
# Deben coincidir con DB_NAME / DB_USER / DB_PASSWORD de arriba.
POSTGRES_DB=rechum
POSTGRES_USER=rechum
POSTGRES_PASSWORD=change-me-in-production

# Versión mayor de PostgreSQL. Debe coincidir con la versión origen del
# dump SQL que vayas a cargar en `db/initdb/`. Valores típicos: 13, 14, 15, 16.
POSTGRES_VERSION=15

# ---- Nginx (host) ---------------------------------------------------
# Puerto del HOST que expone nginx. Usa 8080 si el 80 está ocupado.
HOST_HTTP_PORT=80
